# ════════════════════════════════════════════════════════════════════════════
#  Telegram bot
# ════════════════════════════════════════════════════════════════════════════
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════════════════════════
#  Bot mode
# ════════════════════════════════════════════════════════════════════════════
# "polling" (dev), "webhook" (prod, bot owns the URL), or "receiver"
# (v3 Phase 2: stateless FastAPI in front of RabbitMQ)
MODE=polling

# Required when MODE=webhook or MODE=receiver
WEBHOOK_BASE_URL=https://example.f8f.dev
WEBHOOK_PORT=8080
WEBHOOK_SECRET_TOKEN=change_me_to_random_string

# ════════════════════════════════════════════════════════════════════════════
#  i18n
# ════════════════════════════════════════════════════════════════════════════
# ISO 639-1 fallback locale if the user's Telegram language cannot be detected
# or is not supported by the bot.
DEFAULT_LOCALE=en

# ════════════════════════════════════════════════════════════════════════════
#  Database
# ════════════════════════════════════════════════════════════════════════════
# Supported backends: "sqlite" (default, local dev), "postgres" (v3 scale-out).
# Adding another backend means implementing the interface in
# src/databases/<name>/ and switching this value.
DATABASE_BACKEND=sqlite
DATABASE_PATH=data/bot.db

# Used when DATABASE_BACKEND=postgres. Bare "postgres://" / "postgresql://"
# URLs are both accepted; the async driver (asyncpg) and the Alembic sync
# driver (psycopg) are selected automatically.
POSTGRES_DSN=postgresql://bot:bot@localhost:5432/bot

# ════════════════════════════════════════════════════════════════════════════
#  RabbitMQ (Celery broker)
# ════════════════════════════════════════════════════════════════════════════
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# Queue names
QUEUE_TASKS=tasks_queue
QUEUE_DELIVERY=delivery_queue
QUEUE_DELIVERY_DLQ=delivery_dlq

# ════════════════════════════════════════════════════════════════════════════
#  Incoming-updates transport (MODE=receiver; v3 Phase 2)
# ════════════════════════════════════════════════════════════════════════════
# Exchange the webhook-receiver publishes updates to.
#   ""        — Phase 2: default direct exchange, single UPDATES_QUEUE.
#   "updates" — Phase 3: x-consistent-hash exchange fanning into N
#               shard queues. Per-chat ordering is preserved.
UPDATES_EXCHANGE=
UPDATES_QUEUE=updates_queue

# Phase 3: number of shard queues (updates.shard.0..N-1). In production
# this MUST equal the update-consumer StatefulSet replica count.
UPDATES_SHARDS=16

# How long an update_id stays claimed in Redis (dedup window, seconds).
DEDUP_TTL_SECONDS=3600

# ════════════════════════════════════════════════════════════════════════════
#  Redis (cache + Celery result backend)
# ════════════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# Expiry for values stored by /redis_save (seconds). 0 = never expire.
REDIS_SAVE_TTL=3600

# ════════════════════════════════════════════════════════════════════════════
#  Delivery worker (Telegram Bot API rate-limit)
# ════════════════════════════════════════════════════════════════════════════
# Global messages-per-second ceiling.  Telegram allows ~30 msg/s globally.
DELIVERY_RATE_PER_SECOND=25

# Per-chat messages-per-second ceiling.  Telegram allows ~1 msg/s per chat.
DELIVERY_RATE_PER_CHAT=1
