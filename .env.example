# ════════════════════════════════════════════════════════════════════════════
#  Telegram
# ════════════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=1234567890:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════════════════════════
#  Webhook
# ════════════════════════════════════════════════════════════════════════════
WEBHOOK_BASE_URL=https://example.f8f.dev
WEBHOOK_PORT=8080
WEBHOOK_SECRET_TOKEN=change_me_to_random_string

# ════════════════════════════════════════════════════════════════════════════
#  RabbitMQ
# ════════════════════════════════════════════════════════════════════════════
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# Exchange the receiver publishes updates to.
#   ""        — default direct exchange, single UPDATES_QUEUE.
#   "updates" — x-consistent-hash exchange fanning into N shard queues.
UPDATES_EXCHANGE=
UPDATES_QUEUE=updates_queue
UPDATES_SHARDS=16

# ════════════════════════════════════════════════════════════════════════════
#  Redis (dedup)
# ════════════════════════════════════════════════════════════════════════════
REDIS_URL=redis://localhost:6379/0

# How long an update_id stays claimed in Redis (dedup window, seconds).
DEDUP_TTL_SECONDS=3600
