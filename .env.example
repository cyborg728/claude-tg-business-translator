# ── Telegram ─────────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your personal Telegram chat ID (the bot will send translations here).
# Find it by messaging @userinfobot.
OWNER_CHAT_ID=123456789

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_MODEL=gemini-2.0-flash

# ── Translation ───────────────────────────────────────────────────────────────
# Language YOU (the owner) write in — used when translating your replies to users.
# ISO 639-1 code (e.g. ru, en, de, fr, es, …)
OWNER_LANGUAGE=ru

# ── Bot mode ──────────────────────────────────────────────────────────────────
# "polling" (development) or "webhook" (production)
MODE=polling

# Required only when MODE=webhook:
WEBHOOK_URL=https://example.com          # Public base URL (no trailing slash)
WEBHOOK_PORT=8080                        # Port the bot listens on inside the container
WEBHOOK_SECRET_TOKEN=change_me_to_random_string

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=data/bot.db

# ── Interface locale ──────────────────────────────────────────────────────────
# Language of the bot's own messages to the owner: "en" or "ru"
LOCALE=ru
