# Copy to secret.yaml (keep OUT of git) and fill in real values.
apiVersion: v1
kind: Secret
metadata:
  name: tg-bot-secrets
type: Opaque
stringData:
  TELEGRAM_BOT_TOKEN: "1234567890:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  WEBHOOK_SECRET_TOKEN: "change_me_to_random_string"
  # ── Postgres credentials (used by postgres.yaml StatefulSet + app) ─────
  POSTGRES_USER: "bot"
  POSTGRES_PASSWORD: "change_me_to_strong_password"
  POSTGRES_DB: "tg_bot"
  # Full DSN assembled by the app: postgresql+asyncpg://POSTGRES_USER:POSTGRES_PASSWORD@POSTGRES_HOST:POSTGRES_PORT/POSTGRES_DB
  # Alembic / migration scripts use the sync variant with psycopg driver.
