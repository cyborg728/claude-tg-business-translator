{
  "__inputs": [],
  "annotations": { "list": [] },
  "description": "Telegram Business Bot — delivery, dedup, receiver, and handler metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Delivery — sent / throttled / error (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "opm" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(deliver_sent_total[1m])) * 60",
          "legendFormat": "sent"
        },
        {
          "expr": "sum(rate(deliver_throttled_total[1m])) * 60",
          "legendFormat": "throttled (429)"
        },
        {
          "expr": "sum(rate(deliver_server_error_total[1m])) * 60",
          "legendFormat": "server error (5xx)"
        }
      ]
    },
    {
      "title": "Delivery — retries & DLQ (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "opm" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(deliver_retried_total[1m])) * 60",
          "legendFormat": "retried"
        },
        {
          "expr": "sum(rate(deliver_dead_lettered_total[1m])) * 60",
          "legendFormat": "dead-lettered"
        }
      ]
    },
    {
      "title": "Dedup — hit / miss (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "opm" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(dedup_miss_total[1m])) * 60",
          "legendFormat": "first-time (miss)"
        },
        {
          "expr": "sum(rate(dedup_hit_total[1m])) * 60",
          "legendFormat": "duplicate (hit)"
        }
      ]
    },
    {
      "title": "Receiver — requests by outcome (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "opm" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(receiver_requests_total[1m])) * 60",
          "legendFormat": "{{ outcome }}"
        }
      ]
    },
    {
      "title": "Receiver — publish latency (p50 / p90 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(receiver_publish_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(receiver_publish_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p90"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(receiver_publish_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Handler — update dispatch latency by shard (p50 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, shard) (rate(handler_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{ shard }}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, shard) (rate(handler_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{ shard }}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["telegram", "bot", "delivery", "rabbitmq"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Telegram Business Bot",
  "uid": "tg-business-bot",
  "version": 1
}
