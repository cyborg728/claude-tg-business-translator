# Telegram Business Bot — русские строки

# ── /start ────────────────────────────────────────────────────────────────────
start-greeting = 👋 Привет, { $name }! Я готов к работе.
start-help =
    Доступные команды:
    /start        — это сообщение
    /test_queue   — поставить в очередь долгую задачу и получить ответ
    /redis_save   — сохранить текст следующего сообщения в Redis
    /redis_read   — вывести сохранённый текст из Redis

# ── /test_queue ───────────────────────────────────────────────────────────────
queue-enqueued = ✅ Запрос поставлен в очередь. Отвечу, как только воркер закончит.
queue-success = 🎉 success
queue-failure = ❌ Во время обработки что-то пошло не так.

# ── /redis_save & /redis_read ─────────────────────────────────────────────────
redis-save-prompt = 📝 Отправь следующее сообщение — я сохраню его в Redis.
redis-save-done = 💾 Сохранено. Вызови /redis_read, чтобы прочитать.
redis-save-cancelled = Сохранение отменено — я уже ждал текст.
redis-read-empty = 🗒 Пока ничего не сохранено. Сначала вызови /redis_save.
redis-read-value = 📖 Твой сохранённый текст:
    <code>{ $value }</code>

# ── Business messages ────────────────────────────────────────────────────────
business-connected = 🔌 Бизнес-подключение добавлено.
business-disconnected = 🔌 Бизнес-подключение удалено.
business-message-received = 📨 Новое сообщение через ваш бизнес-аккаунт.

# ── Errors ────────────────────────────────────────────────────────────────────
error-unknown-command = 🤔 Такой команды я не знаю. Попробуй /start.
error-internal = ⚠️ Упс — что-то пошло не так. Инцидент записан в лог.
